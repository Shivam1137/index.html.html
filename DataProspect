<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DataProspect – Powered by Shivam Palkar</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;800&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>
    <style>
        :root {
            --electric: #00d4ff;
            --electric-dark: #0099cc;
            --gold: #f0a500;
            --navy: #060d1f;
            --navy2: #0a1628;
            --panel: rgba(6,18,45,0.82);
            --panel-border: rgba(0,212,255,0.18);
            --text: #e2f4ff;
            --muted: #7ab0cc;
            --success: #00e5a0;
            --warning: #f0a500;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--navy);
            color: var(--text);
            overflow-x: hidden;
        }

        /* BG IMAGE applied globally */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: url('data:image/jpeg;base64,') center/cover no-repeat;
            filter: brightness(0.28) saturate(1.3);
            z-index: 0;
        }

        /* ── LOGIN ─────────────────────────────────── */
        .login-screen {
            position: fixed;
            inset: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            position: relative;
            z-index: 1;
            background: rgba(6,18,45,0.88);
            border: 1px solid var(--panel-border);
            border-radius: 20px;
            padding: 52px 48px 44px;
            width: 420px;
            max-width: 95vw;
            box-shadow: 0 0 60px rgba(0,212,255,0.12), 0 0 0 1px rgba(0,212,255,0.08);
            backdrop-filter: blur(18px);
            text-align: center;
        }

        .login-logo {
            font-family: 'Orbitron', sans-serif;
            font-size: 26px;
            font-weight: 800;
            color: var(--electric);
            letter-spacing: 2px;
            margin-bottom: 4px;
        }

        .login-sub {
            font-size: 13px;
            color: var(--muted);
            letter-spacing: 1px;
            margin-bottom: 36px;
        }

        .login-field {
            text-align: left;
            margin-bottom: 20px;
        }

        .login-field label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: var(--electric);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .login-field input {
            width: 100%;
            padding: 13px 16px;
            background: rgba(0,212,255,0.06);
            border: 1px solid rgba(0,212,255,0.2);
            border-radius: 8px;
            color: var(--text);
            font-size: 15px;
            font-family: 'Rajdhani', sans-serif;
            transition: all 0.2s;
        }

        .login-field input:focus {
            outline: none;
            border-color: var(--electric);
            background: rgba(0,212,255,0.1);
            box-shadow: 0 0 0 3px rgba(0,212,255,0.1);
        }

        .login-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--electric), #0070ff);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-family: 'Orbitron', sans-serif;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 2px;
            cursor: pointer;
            margin-top: 8px;
            transition: all 0.3s;
            box-shadow: 0 4px 24px rgba(0,212,255,0.3);
        }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(0,212,255,0.5);
        }

        .login-error {
            background: rgba(255,60,60,0.12);
            border: 1px solid rgba(255,60,60,0.35);
            color: #ff6b6b;
            padding: 10px 14px;
            border-radius: 7px;
            font-size: 14px;
            margin-top: 14px;
            display: none;
        }

        .powered-tag {
            font-size: 11px;
            color: rgba(122,176,204,0.5);
            margin-top: 28px;
            letter-spacing: 1px;
        }

        /* ── UPLOAD ─────────────────────────────────── */
        .upload-section {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 50;
            align-items: center;
            justify-content: center;
            flex-direction: column;
        }

        .upload-box {
            position: relative;
            z-index: 1;
            background: var(--panel);
            border: 2px dashed rgba(0,212,255,0.3);
            border-radius: 20px;
            padding: 60px 80px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 40px rgba(0,212,255,0.08);
            max-width: 580px;
            backdrop-filter: blur(16px);
        }

        .upload-box:hover {
            border-color: var(--electric);
            transform: translateY(-4px);
            box-shadow: 0 25px 70px rgba(0,0,0,0.5), 0 0 60px rgba(0,212,255,0.15);
        }

        .upload-logo {
            font-family: 'Orbitron', sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: var(--electric);
            margin-bottom: 8px;
            letter-spacing: 2px;
        }

        .upload-box h2 {
            margin-bottom: 12px;
            font-size: 26px;
            color: var(--text);
            font-weight: 700;
        }

        .upload-box p {
            color: var(--muted);
            font-size: 15px;
            margin-bottom: 24px;
        }

        .upload-box input[type="file"] { display: none; }

        .upload-btn {
            background: linear-gradient(135deg, var(--electric), #0070ff);
            color: white;
            padding: 13px 30px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 15px;
            font-weight: 700;
            font-family: 'Rajdhani', sans-serif;
            letter-spacing: 1px;
            transition: all 0.3s;
            box-shadow: 0 4px 16px rgba(0,212,255,0.35);
        }

        .upload-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(0,212,255,0.55);
        }

        #fileName { margin-top: 18px; color: var(--electric); font-weight: 600; font-size: 14px; }

        .error-message {
            background: rgba(255,60,60,0.12);
            border: 1px solid rgba(255,60,60,0.3);
            color: #ff6b6b;
            padding: 12px 18px;
            border-radius: 8px;
            margin-top: 14px;
            display: none;
            font-size: 14px;
        }

        .warning-message {
            background: rgba(240,165,0,0.12);
            border: 1px solid rgba(240,165,0,0.3);
            color: var(--gold);
            padding: 12px 18px;
            border-radius: 8px;
            margin-top: 14px;
            display: none;
            font-size: 14px;
        }

        /* ── DASHBOARD ───────────────────────────────── */
        .dashboard { display: none; height: 100vh; position: relative; z-index: 1; }

        .top-bar {
            background: rgba(6,18,45,0.85);
            border-bottom: 1px solid rgba(0,212,255,0.15);
            padding: 14px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            backdrop-filter: blur(14px);
            box-shadow: 0 2px 20px rgba(0,0,0,0.3);
            flex-wrap: wrap;
            gap: 14px;
            position: relative;
            z-index: 10;
        }

        .logo {
            font-family: 'Orbitron', sans-serif;
            font-size: 20px;
            font-weight: 800;
            color: var(--electric);
            letter-spacing: 2px;
        }

        .logo span {
            display: block;
            font-family: 'Rajdhani', sans-serif;
            font-size: 11px;
            color: var(--muted);
            letter-spacing: 2px;
            font-weight: 400;
            text-transform: uppercase;
            margin-top: 2px;
        }

        .top-stats { display: flex; gap: 32px; align-items: center; flex-wrap: wrap; }

        .top-stat { text-align: center; }

        .top-stat-label {
            font-size: 11px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 4px;
        }

        .top-stat-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 22px;
            font-weight: 600;
            color: var(--electric);
        }

        .logout-btn {
            padding: 8px 18px;
            background: transparent;
            color: var(--muted);
            border: 1px solid rgba(0,212,255,0.2);
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            font-family: 'Rajdhani', sans-serif;
            font-weight: 600;
            letter-spacing: 1px;
            transition: all 0.2s;
        }

        .logout-btn:hover {
            color: var(--electric);
            border-color: var(--electric);
            background: rgba(0,212,255,0.06);
        }

        .container { display: flex; height: calc(100vh - 65px); }

        /* ── SIDEBAR ─────────────────────────────────── */
        .sidebar {
            width: 310px;
            background: rgba(6,14,35,0.78);
            padding: 24px;
            overflow-y: auto;
            border-right: 1px solid rgba(0,212,255,0.1);
            backdrop-filter: blur(12px);
        }

        .sidebar h2 {
            color: var(--electric);
            font-family: 'Orbitron', sans-serif;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 2px;
            margin-bottom: 24px;
            text-transform: uppercase;
        }

        .filter-section { margin-bottom: 16px; }

        .filter-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            cursor: pointer;
            padding: 10px 12px;
            border-radius: 8px;
            border: 1px solid rgba(0,212,255,0.1);
            background: rgba(0,212,255,0.04);
            transition: all 0.2s;
        }

        .filter-header:hover {
            background: rgba(0,212,255,0.08);
            border-color: rgba(0,212,255,0.2);
        }

        .filter-label {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: 0.5px;
        }

        .filter-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
        .filter-content.expanded { max-height: 400px; overflow-y: auto; }

        .filter-search {
            width: 100%;
            padding: 8px 12px;
            border: 1px solid rgba(0,212,255,0.15);
            border-radius: 6px;
            font-size: 13px;
            margin-bottom: 8px;
            background: rgba(0,212,255,0.05);
            color: var(--text);
            font-family: 'Rajdhani', sans-serif;
            transition: all 0.2s;
        }

        .filter-search:focus {
            outline: none;
            border-color: var(--electric);
            background: rgba(0,212,255,0.1);
        }

        .filter-search::placeholder { color: var(--muted); }

        .filter-options { max-height: 180px; overflow-y: auto; }

        .filter-option {
            display: flex;
            align-items: center;
            padding: 7px 10px;
            cursor: pointer;
            border-radius: 6px;
            transition: all 0.15s;
            font-size: 13px;
            color: var(--muted);
        }

        .filter-option:hover { background: rgba(0,212,255,0.08); color: var(--text); }

        .filter-option input[type="checkbox"] {
            margin-right: 10px;
            width: 15px;
            height: 15px;
            cursor: pointer;
            accent-color: var(--electric);
        }

        .radio-options { display: flex; gap: 10px; flex-wrap: wrap; }

        .radio-option {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--muted);
            cursor: pointer;
        }

        .radio-option input[type="radio"] {
            width: 15px;
            height: 15px;
            cursor: pointer;
            accent-color: var(--electric);
        }

        .apply-btn {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, var(--electric), #0070ff);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 700;
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 1.5px;
            cursor: pointer;
            margin-top: 20px;
            transition: all 0.3s;
            box-shadow: 0 4px 16px rgba(0,212,255,0.3);
        }

        .apply-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(0,212,255,0.5);
        }

        .clear-btn {
            width: 100%;
            padding: 10px;
            background: transparent;
            color: var(--electric);
            border: 1px solid rgba(0,212,255,0.3);
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            font-family: 'Rajdhani', sans-serif;
            cursor: pointer;
            margin-top: 10px;
            transition: all 0.2s;
        }

        .clear-btn:hover {
            background: rgba(0,212,255,0.06);
            border-color: var(--electric);
        }

        /* ── MAIN CONTENT ───────────────────────────── */
        .main-content {
            flex: 1;
            padding: 24px 28px;
            overflow-y: auto;
        }

        .content-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 14px;
        }

        .content-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 20px;
            font-weight: 600;
            color: var(--text);
            letter-spacing: 1px;
        }

        .header-actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }

        .rows-selector {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: var(--muted);
        }

        .rows-selector select {
            padding: 8px 28px 8px 10px;
            border: 1px solid rgba(0,212,255,0.2);
            border-radius: 6px;
            background: rgba(6,18,45,0.8);
            font-size: 13px;
            cursor: pointer;
            color: var(--text);
            font-family: 'Rajdhani', sans-serif;
            transition: all 0.2s;
        }

        .rows-selector select:focus {
            outline: none;
            border-color: var(--electric);
        }

        .export-btn {
            padding: 10px 20px;
            background: transparent;
            color: var(--electric);
            border: 1px solid rgba(0,212,255,0.35);
            border-radius: 8px;
            font-weight: 700;
            font-family: 'Rajdhani', sans-serif;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 13px;
            letter-spacing: 0.5px;
        }

        .export-btn:hover {
            background: var(--electric);
            color: var(--navy);
            box-shadow: 0 4px 16px rgba(0,212,255,0.4);
        }

        /* ── TABLE ───────────────────────────────────── */
        .table-container {
            background: rgba(6,14,35,0.75);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(0,212,255,0.1);
            backdrop-filter: blur(10px);
        }

        .data-table { width: 100%; border-collapse: collapse; }

        .data-table th, .data-table td {
            padding: 13px 14px;
            text-align: left;
            border-bottom: 1px solid rgba(0,212,255,0.07);
        }

        .data-table th {
            background: rgba(0,212,255,0.08);
            color: var(--electric);
            font-size: 11px;
            font-weight: 700;
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .data-table tr:hover { background: rgba(0,212,255,0.04); }

        .data-table td { color: var(--text); font-size: 13px; }

        .email-cell { color: var(--electric); text-decoration: none; }
        .email-cell:hover { text-decoration: underline; }

        .access-wrap { display: flex; align-items: center; gap: 8px; }

        .access-btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            background: rgba(0,212,255,0.08);
            border: 1px solid rgba(0,212,255,0.3);
            border-radius: 6px;
            color: var(--electric);
            font-size: 11px;
            font-weight: 700;
            font-family: 'Rajdhani', sans-serif;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .access-btn:hover {
            background: var(--electric);
            color: var(--navy);
            box-shadow: 0 2px 10px rgba(0,212,255,0.4);
        }

        .access-btn.revealed {
            background: rgba(0,229,160,0.1);
            border-color: rgba(0,229,160,0.3);
            color: var(--success);
            cursor: default;
        }

        .access-btn.revealed:hover {
            background: rgba(0,229,160,0.15);
            color: var(--success);
            box-shadow: none;
        }

        .access-value {
            display: none;
            color: var(--text);
            font-size: 13px;
        }

        .access-value.shown { display: inline; }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .badge-primary { background: rgba(0,212,255,0.15); color: var(--electric); border: 1px solid rgba(0,212,255,0.25); }
        .badge-success { background: rgba(0,229,160,0.12); color: var(--success); border: 1px solid rgba(0,229,160,0.25); }
        .badge-warning { background: rgba(240,165,0,0.12); color: var(--gold); border: 1px solid rgba(240,165,0,0.25); }

        /* ── PAGINATION ─────────────────────────────── */
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            margin-top: 20px;
            padding: 16px;
        }

        .pagination button {
            padding: 8px 16px;
            background: rgba(6,18,45,0.8);
            color: var(--muted);
            border: 1px solid rgba(0,212,255,0.15);
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 13px;
            font-family: 'Rajdhani', sans-serif;
            font-weight: 600;
        }

        .pagination button:hover:not(:disabled) {
            background: var(--electric);
            color: var(--navy);
            border-color: var(--electric);
        }

        .pagination button:disabled { opacity: 0.35; cursor: not-allowed; }
        .pagination span { color: var(--muted); font-size: 13px; }

        /* ── ACTIVE FILTERS ─────────────────────────── */
        .active-filters { display: flex; flex-wrap: wrap; margin-bottom: 14px; min-height: 20px; gap: 4px; }

        .filter-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            background: rgba(0,212,255,0.12);
            border: 1px solid rgba(0,212,255,0.25);
            color: var(--electric);
            border-radius: 10px;
            font-size: 12px;
            font-weight: 600;
        }

        .filter-badge button {
            background: none;
            border: none;
            color: var(--electric);
            cursor: pointer;
            font-size: 14px;
            padding: 0;
            line-height: 1;
        }

        /* ── INSTRUCTION MSG ────────────────────────── */
        .instruction-message {
            background: rgba(0,212,255,0.04);
            border: 1px solid rgba(0,212,255,0.15);
            color: var(--muted);
            padding: 60px 20px;
            border-radius: 12px;
            text-align: center;
            margin: 20px 0;
        }

        .instruction-message h3 {
            font-family: 'Orbitron', sans-serif;
            font-size: 18px;
            color: var(--text);
            margin-bottom: 10px;
            letter-spacing: 1px;
        }

        .instruction-message p { font-size: 15px; }

        /* ── EMPTY STATE ─────────────────────────────── */
        .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
        .empty-state h3 { font-size: 18px; margin-bottom: 8px; color: var(--text); }

        /* ── TOGGLE ICON ─────────────────────────────── */
        .toggle-icon { transition: transform 0.3s; color: var(--muted); font-size: 12px; }
        .toggle-icon.rotated { transform: rotate(180deg); }

        /* ── SCROLLBAR ───────────────────────────────── */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
        ::-webkit-scrollbar-thumb { background: rgba(0,212,255,0.2); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(0,212,255,0.4); }

        @media (max-width: 768px) {
            .sidebar { width: 260px; }
            .upload-box { padding: 40px 24px; }
        }
    </style>
</head>
<body>

<!-- ── LOGIN SCREEN ─────────────────────────────── -->
<div class="login-screen" id="loginScreen">
    <div class="login-card">
        <div class="login-logo">⚡ DataProspect</div>
        <div class="login-sub">Powered by Shivam Palkar</div>

        <div class="login-field">
            <label>Login ID</label>
            <input type="email" id="loginId" placeholder="Enter your login ID" autocomplete="username">
        </div>
        <div class="login-field">
            <label>Password</label>
            <input type="password" id="loginPass" placeholder="Enter your password" autocomplete="current-password">
        </div>
        <button class="login-btn" onclick="doLogin()">ACCESS DASHBOARD</button>
        <div class="login-error" id="loginError">❌ Invalid login credentials. Please try again.</div>
        <div class="powered-tag">© 2026 Data Mapping CRM | Powered by Shivam Palkar</div>
    </div>
</div>

<!-- ── UPLOAD SCREEN ────────────────────────────── -->
<div class="upload-section" id="uploadSection">
    <div class="upload-box" onclick="document.getElementById('fileInput').click()">
        <div class="upload-logo">⚡ DataProspect</div>
        <h2>📊 Upload Your Data</h2>
        <p>Click to select or drag your CSV file here</p>
        <button class="upload-btn" onclick="event.stopPropagation(); document.getElementById('fileInput').click()">Choose CSV File</button>
        <input type="file" id="fileInput" accept=".csv">
        <p id="fileName"></p>
        <div class="error-message" id="errorMessage"></div>
        <div class="warning-message" id="warningMessage"></div>
    </div>
</div>

<!-- ── DASHBOARD ─────────────────────────────────── -->
<div class="dashboard" id="dashboard">
    <div class="top-bar">
        <div class="logo">
            ⚡ DataProspect
            <span>Powered by Shivam Palkar</span>
        </div>
        <div class="top-stats">
            <div class="top-stat">
                <div class="top-stat-label">Total Contacts</div>
